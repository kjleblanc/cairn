{
  "name": "cairn-desktop",
  "productName": "Cairn",
  "version": "0.1.2",
  "description": "Route one project task at a time and keep an honest local record",
  "author": "Ken LeBlanc",
  "license": "MIT",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "prestart": "node scripts/copy-assets.mjs",
    "start": "electron-forge start",
    "premake": "node scripts/copy-assets.mjs",
    "make": "electron-forge make",
    "prepackage": "node scripts/copy-assets.mjs",
    "package": "electron-forge package",
    "typecheck": "tsc --noEmit",
    "build:vite": "node scripts/copy-assets.mjs && vite build -c vite.main.config.ts && vite build -c vite.preload.config.ts && vite build -c vite.renderer.config.ts",
    "test:smoke": "npm run build:vite && playwright test",
    "test:unit": "tsc -p tsconfig.unit.json && node --test dist-unit/tests-unit/*.test.js"
  },
  "dependencies": {
    "@cairn/core": "file:../core",
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-dmg": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@electron-forge/plugin-vite": "^7.5.0",
    "@fontsource/quicksand": "^5.1.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
