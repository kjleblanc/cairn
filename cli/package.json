    "start": "npm run build && node dist/src/index.js"
  },
  "dependencies": {
    "@cairn/core": "*",
    "@clack/prompts": "^0.11.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
