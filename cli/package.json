{
  "name": "cairn-cli",
  "version": "0.1.1",
  "description": "Cairn — one serial task route for people who do not code",
  "license": "MIT",
  "type": "module",
  "bin": { "cairn": "dist/src/index.js" },
  "files": ["dist/src"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc",
